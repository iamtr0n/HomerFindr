# HomerFindr Configuration
# Copy this file to .env and fill in your values.

# ── Web Server ────────────────────────────────────────────────
# HOST=127.0.0.1
# PORT=8001

# ── Database ──────────────────────────────────────────────────
# Default: ~/.homesearch/homesearch.db
# DATABASE_PATH=/path/to/custom.db

# ── AI Offer Estimates (optional) ────────────────────────────
# Powers the AI analysis + photo condition assessment on listing cards.
# Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── Commute Estimation ────────────────────────────────────────
# Set your work address to show estimated commute times on listings.
# WORK_ADDRESS=123 Main St, Austin TX 78701
# WORK_LAT=30.2672
# WORK_LNG=-97.7431

# ── Email Reports (optional) ─────────────────────────────────
# Daily digest of new listings for all active saved searches.
# Uses Gmail App Password — enable 2FA first, then generate one at:
# https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# REPORT_EMAIL=recipient@gmail.com
# REPORT_HOUR=7
# REPORT_MINUTE=0

# ── Zapier Webhook (optional) ────────────────────────────────
# Receive new listing alerts via Zapier → SMS, Slack, etc.
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# ── Background Polling (optional) ────────────────────────────
# Auto-refresh active saved searches in the background.
# BACKGROUND_POLLING_ENABLED=false
# BACKGROUND_POLL_INTERVAL_MINUTES=60
# USER_TIMEZONE=America/Chicago

# ── Household Sharing (optional) ─────────────────────────────
# Set a shared 6-character code so multiple family members
# see the same saved searches and dismissed listings.
# HOUSEHOLD_SESSION=ABC123
