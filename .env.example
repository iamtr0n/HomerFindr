# Home Search Aggregator Configuration

# SMTP Settings for daily email reports
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
REPORT_EMAIL=your_email@gmail.com

# Optional: RapidAPI key for paid data sources (Zillow, etc.)
# RAPIDAPI_KEY=your_key_here

# Database path (default: ./homesearch.db)
# DATABASE_PATH=./homesearch.db

# Web server
# HOST=127.0.0.1
# PORT=8000

# Report schedule (24h format)
# REPORT_HOUR=7
# REPORT_MINUTE=0
